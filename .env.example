# ruby-code — API keys
# Copy this file to .env and fill in the keys you need.
# Never commit .env to git.

# Anthropic (Claude models)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT models)
OPENAI_API_KEY=sk-...

# Google (Gemini models)
GOOGLE_API_KEY=...

# xAI (Grok models)
XAI_API_KEY=...

# OpenRouter (access to all models via one key)
OPENROUTER_API_KEY=sk-or-...

# Xiaomi MiMo — get from platform.xiaomimimo.com/api-keys
# Token Plan endpoint (Singapore by default — change region if needed)
XIAOMI_API_KEY=tp-...
XIAOMI_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1

# Default model (overridden by --model flag)
# RUBY_MODEL=mimo-v2.5-pro
